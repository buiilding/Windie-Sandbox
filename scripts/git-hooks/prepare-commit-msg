#!/usr/bin/env bash
set -euo pipefail

if [ "${WINDIE_COMMIT_WITH_BENCH:-0}" = "1" ]; then
    exit 0
fi

cat >&2 <<'MESSAGE'
direct git commit is disabled in this repository.

Use:
  scripts/commit-with-bench.sh -m "subject" -m "description"
  scripts/commit-with-bench.sh -F commit-message.txt

The wrapper runs the provider-free benchmark and appends the comparison to the
commit message before invoking git commit.

provide an explicit description of that commit. The description should state
what changed, why it changed, and which behavior or code boundary the commit
affects.
MESSAGE

exit 1
